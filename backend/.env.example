# Backend environment (copy to .env for local dev).

# --- Database (Supabase Postgres, async driver) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Supabase auth (JWT verification) ---
SUPABASE_URL=http://localhost:54321
# For local dev the CLI prints a JWT secret; set it for HS256 verification.
# Leave blank in production to use asymmetric JWKS verification.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# --- API ---
CORS_ORIGINS=["http://localhost:3000"]
API_HOST=0.0.0.0
API_PORT=8000
# Optional shared secret for admin/scrape endpoints.
ADMIN_API_SECRET=

# --- Scraper ---
SCRAPE_INTERVAL_SECONDS=300
SCRAPE_BATCH_SIZE=5
SCRAPE_CONCURRENCY=3
SCRAPE_HTTP_TIMEOUT_SECONDS=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
