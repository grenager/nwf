# Backend environment (copy to .env for local dev).

# --- Database (Supabase Postgres, async driver) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Supabase auth (JWT verification) ---
SUPABASE_URL=http://localhost:54321
# For local dev the CLI prints a JWT secret; set it for HS256 verification.
# Leave blank in production to use asymmetric JWKS verification.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
# Service-role key (admin Auth generateLink). Optional locally — invites
# degrade to a copyable link when unset.
SUPABASE_SERVICE_ROLE_KEY=

# --- App / email (invitations) ---
APP_BASE_URL=http://localhost:3000
# Resend API key. Optional locally — invite emails are skipped when unset.
RESEND_API_KEY=
EMAIL_FROM=NewsWithFriends <noreply@newswithfriends.org>

# --- API ---
CORS_ORIGINS=["http://localhost:3000"]
API_HOST=0.0.0.0
API_PORT=8000
# Optional shared secret for admin/scrape endpoints.
ADMIN_API_SECRET=

# --- Scraper ---
SCRAPE_INTERVAL_SECONDS=300
SCRAPE_BATCH_SIZE=5
SCRAPE_CONCURRENCY=3
SCRAPE_HTTP_TIMEOUT_SECONDS=20

# --- Embeddings (OpenAI text-embedding-3-small) ---
# Leave blank to skip embedding/clustering (stories ingest normally).
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EVENT_CLUSTER_THRESHOLD=0.82
EVENT_ACTIVE_HOURS=48

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
